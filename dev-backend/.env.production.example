# PlanQ 운영(production) 환경변수 템플릿
#
# 사용:
#   cp .env.production.example /opt/planq/prod-backend/.env
#   # 모든 placeholder 값을 운영 값으로 채움
#   pm2 reload /opt/planq/scripts/prod-ecosystem.config.js
#
# 보안:
#   - 이 파일은 .gitignore 에 포함 (실제 .env 가 절대 commit 되지 않게)
#   - 이 .example 파일도 placeholder 만 — 실제 secret 절대 채우지 말 것

# ═══════════════════════════════════════════════════════════
# 기본
# ═══════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3002
SITE_URL=https://planq.kr
APP_URL=https://planq.kr
ALLOWED_ORIGINS=https://planq.kr,https://www.planq.kr

# ═══════════════════════════════════════════════════════════
# DB (운영 전용 — dev DB 와 분리)
# ═══════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=3306
DB_NAME=planq_prod_db
DB_USER=planq_admin
DB_PASSWORD=<운영_DB_비밀번호>

# ═══════════════════════════════════════════════════════════
# JWT (운영용 신규 발급 — dev 와 절대 동일하게 두지 말 것)
#   생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════════════════════
JWT_SECRET=<64바이트_hex>
JWT_REFRESH_SECRET=<별도_64바이트_hex>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════
# OpenAI (Cue, Q Note LLM, 임베딩, 번역)
# ═══════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-<운영_OPENAI_키>

# ═══════════════════════════════════════════════════════════
# SMTP — 운영 진입 필수 (송장/서명/계정 메일)
#   추천: AWS SES, SendGrid, Mailgun
#   미설정 시 sent=false (memory: project_smtp_pending)
# ═══════════════════════════════════════════════════════════
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="PlanQ <noreply@planq.kr>"

# ═══════════════════════════════════════════════════════════
# Google Drive OAuth (선택 — 외부 클라우드 저장소)
#   리다이렉트 URI 를 운영 도메인으로 등록 필수
# ═══════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=<google_oauth_client_id>
GOOGLE_CLIENT_SECRET=<google_oauth_client_secret>
GOOGLE_REDIRECT_URI=https://planq.kr/api/cloud/callback/gdrive

# ═══════════════════════════════════════════════════════════
# Q Note STT — Deepgram
# ═══════════════════════════════════════════════════════════
DAILY_API_KEY=<deepgram_api_key>

# ═══════════════════════════════════════════════════════════
# 내부 API (Python Q Note ↔ Node 통신)
#   생성: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════
INTERNAL_API_KEY=<32바이트_hex>

# ═══════════════════════════════════════════════════════════
# PlanQ SaaS 자체결제 계좌 (P-2 — 사용자가 PlanQ 구독료 송금)
#   운영 진입 시 PlanQ 의 실제 계좌로 입력 필수
# ═══════════════════════════════════════════════════════════
PLANQ_BILLING_BANK_NAME=<예: 토스뱅크>
PLANQ_BILLING_BANK_ACCOUNT=<예: 100-1234-5678>
PLANQ_BILLING_BANK_HOLDER=PlanQ

# ═══════════════════════════════════════════════════════════
# Web Push (P-6.5)
#   생성: cd /opt/planq/dev-backend && npx web-push generate-vapid-keys
#   미설정 시 push 비활성 (운영 진입 후 설정 가능)
# ═══════════════════════════════════════════════════════════
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@planq.kr

# ═══════════════════════════════════════════════════════════
# PortOne V2 (K 사이클 — 운영 도메인 확정 후 마지막 단계)
#   채널 발급: https://admin.portone.io
# ═══════════════════════════════════════════════════════════
PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_CHANNEL_KEY_BILLING=
PORTONE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════
# (Deprecated) Dropbox — 2026-04-22 정책 변경으로 미사용. 빈 값 유지.
# ═══════════════════════════════════════════════════════════
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=

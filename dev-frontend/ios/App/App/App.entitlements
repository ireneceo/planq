<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  APNs 환경. development = sandbox (Xcode 실기기 Run).
	  TestFlight/App Store 빌드는 Apple 이 배포 시 자동으로 production 으로 승격하므로
	  이 값을 production 으로 바꿀 필요 없다. 서버 쪽만 APNS_PRODUCTION=true 로 맞춘다.
	  (MOBILE_APP_DESIGN §9.1 / services/apns_sender.js 의 sandbox·production 분기와 대응)
	-->
	<key>aps-environment</key>
	<string>development</string>

	<!--
	  Universal Links — planq.kr / dev.planq.kr 로의 302 복귀(OAuth 연동)와 알림 딥링크에 사용.
	  실제 발화하려면 각 도메인이 /.well-known/apple-app-site-association 을
	  application/json 으로 서빙해야 한다 (nginx location + AASA 파일).
	  AASA 의 appID 는 <TEAM_ID>.app.planq — Team ID 수령 후 치환.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:planq.kr</string>
		<string>applinks:dev.planq.kr</string>
	</array>
</dict>
</plist>
